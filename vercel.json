{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/candid-moments", "destination": "/a-thousand-words", "permanent": true },
    { "source": "/candid-moments/:path*", "destination": "/a-thousand-words/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/a-thousand-words/:category", "destination": "/a-thousand-words/category" }
  ],
  "crons": [
    { "path": "/api/admin/blog-posts?task=publish-scheduled", "schedule": "*/10 * * * *" }
  ]
}
